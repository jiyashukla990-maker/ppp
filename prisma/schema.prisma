generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  email     String   @unique
  image     String?
  createdAt DateTime @default(now())

  apps      App[]
}

model App {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String @unique
  supabaseUrl String
  userId      String @db.ObjectId

  user        User   @relation(fields: [userId], references: [id])
}